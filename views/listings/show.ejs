<% layout("/layouts/boilerplate")%>
<div id="react-listing-detail-root" class="react-detail-root"></div>
<script id="react-listing-detail-data" type="application/json">
  <%- JSON.stringify(reactListingData).replace(/</g, "\\u003c") %>
</script>

<div class="legacy-show-shell">
  <div class="listing-detail mt-3">
    <div class="listing-detail-header">
      <div>
        <p class="filters-kicker mb-1"><%= listing.category || 'Stay' %></p>
        <h3><%= listing.title %></h3>
        <p class="listing-meta mb-0">
          <%= listing.location %>, <%= listing.country %> <% if (averageRating)
          { %> · <i class="fa-solid fa-star"></i>
          <%= averageRating %>
          (<%= listing.reviews.length %>
          reviews)
          <% } %>
        </p>
      </div>
      <% if (currUser) { %>
      <form method="POST" action="/listings/<%= listing._id %>/favorite">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button
          class="btn <%= isFavorite ? 'btn-dark' : 'btn-outline-dark' %>"
          type="submit"
        >
          <i class="<%= isFavorite ? 'fa-solid' : 'fa-regular' %> fa-heart"></i>
          <%= isFavorite ? 'Saved' : 'Save' %>
        </button>
      </form>
      <% } %>
    </div>

    <div class="show-card listing-card">
      <img
        src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&w=900&q=80' %>"
        class="card-img-top show-img"
        alt="<%= listing.title %>"
      />
      <div class="card-body">
        <p class="card-text mb-3">
          Owned by <i><%= listing.owner?.username || "Unknown host" %></i>
        </p>

        <p class="card-text listing-description"><%= listing.description %></p>

        <div class="show-facts">
          <span
            ><i class="fa-solid fa-indian-rupee-sign"></i>
            <%= listing.price.toLocaleString("en-IN") %>
            / night</span
          >
          <span
            ><i class="fa-solid fa-user-group"></i>
            <%= listing.guests || 2 %>
            guests</span
          >
          <span
            ><i class="fa-solid fa-bed"></i>
            <%= listing.bedrooms || 1 %>
            bedrooms</span
          >
          <span
            ><i class="fa-solid fa-bath"></i>
            <%= listing.bathrooms || 1 %>
            baths</span
          >
        </div>

        <% if (listing.amenities && listing.amenities.length > 0) { %>
        <div class="amenities-list">
          <% for (let amenity of listing.amenities) { %>
          <span
            ><i class="fa-solid fa-check"></i>
            <%= amenity %></span
          >
          <% } %>
        </div>
        <% } %>
      </div>
    </div>

    <% if (listing.geometry && listing.geometry.coordinates && listing.geometry.coordinates.length === 2) { %>
    <div class="mt-4">
      <h4>Where you'll be</h4>
      <div
        id="listing-map"
        class="listing-map"
        data-lng="<%= listing.geometry.coordinates[0] %>"
        data-lat="<%= listing.geometry.coordinates[1] %>"
        data-title="<%= listing.title %>"
        data-location="<%= `${listing.location}, ${listing.country}` %>"
      ></div>
      <a
        href="https://www.openstreetmap.org/?mlat=<%= listing.geometry.coordinates[1] %>&mlon=<%= listing.geometry.coordinates[0] %>#map=12/<%= listing.geometry.coordinates[1] %>/<%= listing.geometry.coordinates[0] %>"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-outline-dark btn-sm mt-3"
      >
        Open in OpenStreetMap
      </a>
    </div>
    <% } %>

    <% if (currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>
    <div class="btns owner-actions">
      <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark edit-btn"
        >Edit</a
      >

      <form method="post" action="/listings/<%=listing._id%>?_method=DELETE&_csrf=<%= csrfToken %>">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button class="btn btn-outline-danger">Delete</button>
      </form>
    </div>
    <% } %>
  </div>

  <div class="review-shell mb-3">
    <hr />
    <% if(currUser){%>
    <h4>Leave a Review</h4>
    <form
      action="/listings/<%=listing.id%>/reviews"
      method="POST"
      novalidate
      class="needs-validation"
    >
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="mb-3 mt-3">
        <label for="rating" class="form-label">Rating</label>
        <fieldset class="starability-slot">
          <input
            type="radio"
            id="no-rate"
            class="input-no-rate"
            name="review[rating]"
            value="1"
            checked
            aria-label="No rating."
          />
          <input
            type="radio"
            id="first-rate1"
            name="review[rating]"
            value="1"
          />
          <label for="first-rate1" title="Terrible">1 star</label>
          <input
            type="radio"
            id="first-rate2"
            name="review[rating]"
            value="2"
          />
          <label for="first-rate2" title="Not good">2 stars</label>
          <input
            type="radio"
            id="first-rate3"
            name="review[rating]"
            value="3"
          />
          <label for="first-rate3" title="Average">3 stars</label>
          <input
            type="radio"
            id="first-rate4"
            name="review[rating]"
            value="4"
          />
          <label for="first-rate4" title="Very good">4 stars</label>
          <input
            type="radio"
            id="first-rate5"
            name="review[rating]"
            value="5"
          />
          <label for="first-rate5" title="Amazing">5 stars</label>
        </fieldset>
      </div>
      <div class="mb-3 mt-3">
        <label for="comment" class="form-label d-block">Comments</label>
        <textarea
          name="review[comment]"
          id="comment"
          rows="5"
          class="form-control"
          required
        ></textarea>
        <div class="invalid-feedback">Please enter a review comment.</div>
      </div>
      <button class="btn btn-outline btn-dark">Submit</button>
    </form>
    <% } %>

    <hr />
    <p><b>All Reviews</b></p>
    <% if (listing.reviews.length === 0) { %>
    <p class="listing-meta">No reviews yet.</p>
    <% } %>

    <div class="row">
      <% for (let review of listing.reviews) { %>
      <div class="col-md-6 mb-3">
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title">@<%= review.author.username %></h5>
            <p
              class="starability-result card-text"
              data-rating="<%= review.rating %>"
            ></p>
            <p class="card-text"><%= review.comment %></p>
            <% if (currUser && currUser._id.equals(review.author._id)) { %>
            <form
              class="mb-3"
              method="POST"
              action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE&_csrf=<%= csrfToken %>"
            >
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button class="btn btn-sm btn-dark">Delete</button>
            </form>
            <% } %>
          </div>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>
