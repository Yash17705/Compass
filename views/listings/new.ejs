<% layout("/layouts/boilerplate")%>
<div class="form-shell">
  <div class="form-panel">
    <br /><br />
    <p class="filters-kicker mb-1">Host dashboard</p>
    <h3>Create a new listing</h3>
    <form
      method="POST"
      action="/listings"
      class="needs-validation"
      novalidate
      enctype="multipart/form-data"
    >
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input
          name="listing[title]"
          placeholder="enter title"
          class="form-control"
          required
        />
        <div class="valid-feedback">Title looks good!</div>
      </div>
      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="category" class="form-label">Category</label>
          <select
            id="category"
            name="listing[category]"
            class="form-select"
            required
          >
            <% for (let filter of filters.filter((item) => item.key !==
            'trending')) { %>
            <option value="<%= filter.key %>"><%= filter.label %></option>
            <% } %>
          </select>
        </div>
        <div class="mb-3 col-md-8">
          <label class="form-label">Amenities</label>
          <div class="amenity-grid">
            <% for (let amenity of amenities) { %>
            <label class="amenity-choice">
              <input
                type="checkbox"
                name="listing[amenities]"
                value="<%= amenity %>"
              />
              <span><%= amenity %></span>
            </label>
            <% } %>
          </div>
        </div>
      </div>
      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea
          name="listing[description]"
          class="form-control"
          placeholder="Add Description"
          required
        ></textarea>
        <div class="invalid-feedback">Add a Description</div>
      </div>
      <div class="mb-3">
        <label for="image" class="form-label">Upload Image</label>
        <input
          name="image"
          type="file"
          accept="image/*"
          class="form-control"
          required
        />
      </div>
      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="price" class="form-label">Price</label>
          <input
            name="listing[price]"
            placeholder="enter price"
            type="number"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Enter Price</div>
        </div>
        <div class="mb-3 col-md-4">
          <label for="guests" class="form-label">Guests</label>
          <input
            id="guests"
            name="listing[guests]"
            type="number"
            min="1"
            value="2"
            class="form-control"
            required
          />
        </div>
        <div class="mb-3 col-md-4">
          <label for="bedrooms" class="form-label">Bedrooms</label>
          <input
            id="bedrooms"
            name="listing[bedrooms]"
            type="number"
            min="0"
            value="1"
            class="form-control"
            required
          />
        </div>
      </div>
      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="bathrooms" class="form-label">Bathrooms</label>
          <input
            id="bathrooms"
            name="listing[bathrooms]"
            type="number"
            min="0"
            value="1"
            class="form-control"
            required
          />
        </div>
        <div class="mb-3 col-md-8">
          <label for="country" class="form-label">Country</label>
          <input
            id="country"
            name="listing[country]"
            placeholder="enter country"
            type="text"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Enter your country</div>
        </div>
      </div>
      <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input
          id="location"
          name="listing[location]"
          placeholder="enter location"
          type="text"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Enter location</div>
      </div>
      <div class="mb-3">
        <button
          type="button"
          class="btn btn-outline-dark location-check-btn"
          data-map-target="listing-form-map"
          data-location-input="location"
          data-country-input="country"
        >
          Check location
        </button>
      </div>
      <div class="mb-3">
        <div id="listing-form-map" class="listing-map d-none"></div>
        <p
          id="listing-form-map-status"
          class="location-status text-muted mt-2 mb-0"
        ></p>
      </div>
      <button type="submit" class="btn btn-dark add-btn mt-3">Add</button>
      <br /><br />
    </form>
  </div>
</div>
